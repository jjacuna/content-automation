# =============================================================
# Content Automation Demo — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# -- App Config --
SECRET_KEY=change-me-in-production       # Flask session secret
PORT=5000                                 # Server port

# -- Auth (simple session-based) --
ADMIN_USER=admin                          # Login username
ADMIN_PASS=admin                          # Login password

# -- Database --
DATABASE_PATH=content.db                  # SQLite file path

# -- OpenRouter (LLM — required for text generation) --
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# -- FireCrawl (URL scraping — required for Phase 2+) --
# Get your key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# -- Kie.ai (Image + Video generation — required for Phase 3-4) --
# Get your key at: https://kie.ai/
KIE_API_KEY=

# -- GetLate.dev (Publishing — required for Phase 6) --
# Get your key at: https://getlate.dev/
GETLATE_API_KEY=

# -- Optional --
APP_URL=http://localhost:5000             # Used in OpenRouter HTTP-Referer header

# -- Cloudflare R2 Storage (permanent media URLs) --
# Get your keys at: https://dash.cloudflare.com/ > R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
